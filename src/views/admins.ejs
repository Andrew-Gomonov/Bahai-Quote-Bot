<h2 class="mb-4">Администраторы</h2>

<div class="row">
  <div class="col-md-6">
    <h4 class="d-flex justify-content-between align-items-center">Telegram <button class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#addTgModal">+ Добавить</button></h4>
    <table id="tgTbl" class="table table-striped table-hover w-100 dt-responsive nowrap">
      <thead><tr><th>ID</th><th class="text-center">Действия</th></tr></thead>
      <tbody>
      <% tgAdmins.forEach(function(r){ %>
        <tr>
          <td><%= r.chat_id %></td>
          <td class="text-center">
            <form method="POST" action="/admins/delete/<%= r.chat_id %>" onsubmit="return confirm('Удалить Telegram-админа?');"><button class="btn btn-sm btn-danger">Удалить</button></form>
          </td>
        </tr>
      <% }); %>
      </tbody>
    </table>
  </div>
  <div class="col-md-6">
    <h4 class="d-flex justify-content-between align-items-center">Web-панель <button class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#addWebModal">+ Добавить</button></h4>
    <table id="webTbl" class="table table-striped table-hover w-100 dt-responsive nowrap">
      <thead><tr><th>Username</th><th class="text-center">Действия</th></tr></thead>
      <tbody>
      <% webAdmins.forEach(function(r){ %>
        <tr>
          <td><%= r.username %></td>
          <td class="text-center">
            <form method="POST" action="/admins/delete-web/<%= r.username %>" onsubmit="return confirm('Удалить веб-админа?');"><button class="btn btn-sm btn-danger">Удалить</button></form>
          </td>
        </tr>
      <% }); %>
      </tbody>
    </table>
  </div>
</div>

<!-- Modals -->
<div class="modal fade" id="addTgModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <form method="POST" action="/admins">
        <div class="modal-header"><h5 class="modal-title">Новый Telegram-админ</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body"><input type="number" name="chat_id" class="form-control" placeholder="Telegram chat ID" required></div>
        <div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button><button class="btn btn-primary">Добавить</button></div>
      </form>
    </div>
  </div>
</div>

<div class="modal fade" id="addWebModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <form method="POST" action="/admins/web">
        <div class="modal-header"><h5 class="modal-title">Новый веб-админ</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <input type="text" name="username" class="form-control mb-2" placeholder="Username" required>
          <input type="password" name="password" class="form-control" placeholder="Password" required>
        </div>
        <div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button><button class="btn btn-primary">Сохранить</button></div>
      </form>
    </div>
  </div>
</div>

<script>
 (function dt(){
   if(window.$ && $.fn.dataTable){
     $('#tgTbl').DataTable({pageLength:30,responsive:true,autoWidth:false,language:{url:'https://cdn.datatables.net/plug-ins/1.13.6/i18n/ru.json'}});
     $('#webTbl').DataTable({pageLength:30,responsive:true,autoWidth:false,language:{url:'https://cdn.datatables.net/plug-ins/1.13.6/i18n/ru.json'}});
   } else { setTimeout(dt,50); }
 })();
</script> 