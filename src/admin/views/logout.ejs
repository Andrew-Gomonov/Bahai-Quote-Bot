<!DOCTYPE html>
<html>
<head>
  <title>Выход из системы</title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6 col-xl-5 text-center">
      <div class="py-4">
        <i class="bi bi-box-arrow-left display-1 text-danger mb-3"></i>
        <h2 class="mb-3">Выход из системы</h2>
        <p class="lead mb-4">Вы уверены, что хотите завершить текущую сессию?</p>
        <form method="POST" action="/logout" class="d-inline-block me-2">
          <button type="submit" class="btn btn-danger btn-lg"><i class="bi bi-check-circle-fill me-1"></i>Да, выйти</button>
        </form>
        <a href="/" class="btn btn-secondary btn-lg"><i class="bi bi-x-circle-fill me-1"></i>Отмена</a>
      </div>
    </div>
  </div>
</body>
</html> 