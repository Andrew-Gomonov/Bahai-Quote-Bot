<h2 class="mb-4"><i class="bi bi-bar-chart-line-fill"></i> Статистика</h2>
<div class="row text-center">
  <div class="col-md-4 mb-3">
    <div class="card text-bg-primary shadow h-100">
      <div class="card-body d-flex flex-column justify-content-center align-items-center">
        <div class="display-4 mb-2"><i class="bi bi-quote"></i></div>
        <h3 class="display-6"><%= quotes %></h3>
        <p class="lead mb-0">Цитат</p>
      </div>
    </div>
  </div>
  <div class="col-md-4 mb-3">
    <div class="card text-bg-success shadow h-100">
      <div class="card-body d-flex flex-column justify-content-center align-items-center">
        <div class="display-4 mb-2"><i class="bi bi-people-fill"></i></div>
        <h3 class="display-6"><%= users %></h3>
        <p class="lead mb-0">Пользователей</p>
      </div>
    </div>
  </div>
  <div class="col-md-4 mb-3">
    <div class="card text-bg-warning shadow h-100">
      <div class="card-body d-flex flex-column justify-content-center align-items-center">
        <div class="display-4 mb-2"><i class="bi bi-broadcast"></i></div>
        <h3 class="display-6"><%= broadcasts %></h3>
        <p class="lead mb-0">Рассылок</p>
      </div>
    </div>
  </div>
</div>

<div class="card shadow-sm mt-4">
  <div class="card-header fs-5">
    <i class="bi bi-pie-chart-fill"></i> Распределение данных
  </div>
  <div class="card-body p-4">
    <canvas id="statsChart" style="max-height: 300px; margin: 0 auto;"></canvas>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
const ctx = document.getElementById('statsChart').getContext('2d');
new Chart(ctx, {
  type: 'doughnut',
  data: {
    labels: ['Цитаты', 'Пользователи', 'Рассылки'],
    datasets: [{
      data: [<%= quotes %>, <%= users %>, <%= broadcasts %>],
      backgroundColor: ['#0d6efd', '#198754', '#ffc107'],
    }]
  },
  options: { plugins: { legend: { position: 'bottom' } } }
});
</script>