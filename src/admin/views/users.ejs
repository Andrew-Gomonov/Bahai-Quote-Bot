<h2 class="mb-3 d-flex justify-content-between align-items-center">Пользователи
  <div>
    <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#addUserModal">+ Добавить</button>
  </div>
</h2>
<table id="usersTbl" class="table table-striped table-hover dt-responsive nowrap" style="width:100%">
  <thead>
    <tr><th>ID</th><th>Timezone</th><th>Daily time</th><th>Sub</th><th>Last daily</th><th class="text-center">Действия</th></tr>
  </thead>
  <tbody>
  <% rows.forEach(function(u){ %>
    <tr data-id="<%= u.chat_id %>" data-tz="<%= u.timezone %>" data-time="<%= u.daily_time %>" data-sub="<%= u.subscribed %>">
      <td><%= u.chat_id %></td>
      <td><%= u.timezone %></td>
      <td><%= u.daily_time %></td>
      <td><%= u.subscribed? '✅':'❌' %></td>
      <td><%= u.last_daily_sent || '-' %></td>
      <td>
        <div class="btn-group btn-group-sm">
          <button type="button" class="btn btn-outline-primary edit-user" data-id="<%= u.chat_id %>" data-tz="<%= u.timezone %>" data-time="<%= u.daily_time %>" data-sub="<%= u.subscribed %>">✏️</button>
          <form method="POST" action="/users/delete/<%= u.chat_id %>" onsubmit="return confirm('Удалить пользователя?');">
            <button class="btn btn-danger">🗑️</button>
          </form>
        </div>
      </td>
    </tr>
  <% }); %>
  </tbody>
</table>

<!-- Add user modal -->
<div class="modal fade" id="addUserModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <form method="POST" action="/users">
        <div class="modal-header"><h5 class="modal-title">Новый пользователь</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <input type="number" name="chat_id" class="form-control mb-2" placeholder="Telegram chat_id" required>
          <input type="text" name="timezone" class="form-control mb-2" placeholder="Timezone (e.g. Europe/Chisinau)">
          <input type="time" name="daily_time" class="form-control mb-2" placeholder="09:00">
        </div>
        <div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button><button class="btn btn-primary">Добавить</button></div>
      </form>
    </div>
  </div>
</div>

<!-- Edit user modal -->
<div class="modal fade" id="editUserModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <form method="POST" id="editUserForm" action="">
        <div class="modal-header"><h5 class="modal-title">Редактировать пользователя</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <input type="text" name="timezone" class="form-control mb-2" placeholder="Timezone" required>
          <input type="time" name="daily_time" class="form-control mb-2" placeholder="09:00" required>
          <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="subscribedChk" name="subscribed" value="1">
            <label class="form-check-label" for="subscribedChk">Подписан</label>
          </div>
        </div>
        <div class="modal-footer"><button class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button><button class="btn btn-primary">Сохранить</button></div>
      </form>
    </div>
  </div>
</div>

<script>
 // edit button handler
 document.addEventListener('click', function(e){
   const btn=e.target.closest('.edit-user'); if(!btn) return;
   const id=btn.dataset.id;
   const tz=btn.dataset.tz;
   const time=btn.dataset.time;
   const sub=btn.dataset.sub==='1';
   const form=document.getElementById('editUserForm');
   form.action='/users/update/'+id;
   form.timezone.value=tz;
   form.daily_time.value=time;
   document.getElementById('subscribedChk').checked=sub;
   const modal=new bootstrap.Modal(document.getElementById('editUserModal'));
   modal.show();
 });
 (function dt(){if(window.$&&$.fn.dataTable){$('#usersTbl').DataTable({pageLength:25,responsive:true,autoWidth:false,language:{url:'https://cdn.datatables.net/plug-ins/1.13.6/i18n/ru.json'}});} else {setTimeout(dt,50);}})();
</script> 